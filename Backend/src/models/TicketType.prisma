model TicketType {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?
  type        String // single | couple
  price       Decimal

  cinemaId            String?
  cinema              Cinema?              @relation(fields: [cinemaId], references: [id])
  showtimeTicketTypes ShowtimeTicketType[]
  isActive            Boolean              @default(true)

  createdAt DateTime @default(now())

  @@map("ticketTypes")
}
