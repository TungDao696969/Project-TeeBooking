model CinemaRoom {
  id          String    @id @default(uuid())
  cinemaId    String
  roomName    String
  roomType    String
  totalSeats  Int
  screenType  String?
  soundSystem String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  seats     Seat[]
  showtimes Showtime[]
  cinema    Cinema     @relation(fields: [cinemaId], references: [id])

  @@map("cinema_rooms")
}
