model Seat {
  id         String   @id @default(uuid())
  roomId     String
  seatRow    String
  seatNumber Int
  seatCode   String
  seatType   SeatType
  extraPrice Float    @default(0)
  createdAt  DateTime @default(now())

  room          CinemaRoom     @relation(fields: [roomId], references: [id])
  showtimeSeats ShowtimeSeat[]

  @@map("seats")
}
