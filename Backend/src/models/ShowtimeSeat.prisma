model ShowtimeSeat {
  id          String     @id @default(uuid())
  showtimeId  String
  seatId      String
  status      SeatStatus
  finalPrice  Float
  lockedUntil DateTime?

  showtime Showtime        @relation(fields: [showtimeId], references: [id])
  seat     Seat            @relation(fields: [seatId], references: [id])
  tickets  BookingTicket[]

  @@map("showtime_seats")
}
